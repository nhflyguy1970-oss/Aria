[Desktop Entry]
Version=1.0
Type=Application
Name=AI Workstation
Comment=One-click start — bootstrap services and open Aria
Exec=bash @JARVIS_ROOT@/workstation start --desktop
Icon=@JARVIS_ROOT@/assets/jarvis-tray.png
Path=@JARVIS_ROOT@
Terminal=false
Categories=Development;Utility;
StartupNotify=true
StartupWMClass=aria
Keywords=AI;Workstation;Aria;Jeff;
