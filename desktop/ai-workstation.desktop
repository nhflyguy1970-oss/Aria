[Desktop Entry]
Version=1.0
Type=Application
Name=AI Workstation
Comment=One-click start — bootstrap services and open Aria
Exec=@JARVIS_ROOT@/scripts/desktop-launch-workstation.sh
Icon=@JARVIS_ROOT@/assets/jarvis-tray.png
Path=@HOME@
Terminal=false
Categories=Development;Utility;
StartupNotify=true
StartupWMClass=aria
Keywords=AI;Workstation;Aria;Jeff;
