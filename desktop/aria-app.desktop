[Desktop Entry]
Version=1.0
Type=Application
Name=ARIA (Chrome App)
Comment=Same as ARIA — standalone Chrome window (no browser tabs)
Exec=bash @JARVIS_ROOT@/scripts/launch-jarvis-app.sh
Icon=@JARVIS_ROOT@/assets/jarvis-icon.svg
Path=@JARVIS_ROOT@
Terminal=false
Categories=Development;Utility;
StartupNotify=true
StartupWMClass=ARIA
Keywords=AI;Assistant;ARIA;Desktop;Chrome;
SingleMainWindow=true
