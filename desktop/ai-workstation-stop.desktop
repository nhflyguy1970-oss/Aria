[Desktop Entry]
Version=1.0
Type=Application
Name=Stop AI Workstation
Comment=Stop Aria tray and API server
Exec=@JARVIS_ROOT@/scripts/desktop-launch-workstation.sh stop
Icon=@JARVIS_ROOT@/assets/jarvis-tray.png
Path=@HOME@
Terminal=false
Categories=Development;Utility;
Keywords=AI;Workstation;Aria;Stop;
