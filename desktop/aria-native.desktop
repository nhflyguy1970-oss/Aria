[Desktop Entry]
Version=1.0
Type=Application
Name=ARIA (Native — legacy)
Comment=Optional pywebview window — less stable for coding; use main ARIA shortcut instead
Exec=bash @JARVIS_ROOT@/scripts/launch-jarvis-native.sh
Icon=@JARVIS_ROOT@/assets/jarvis-icon.svg
Path=@JARVIS_ROOT@
Terminal=false
Categories=Development;Utility;
StartupNotify=true
StartupWMClass=ARIA
Keywords=AI;Assistant;ARIA;Desktop;Native;Legacy;
SingleMainWindow=true
