[Desktop Entry]
Version=1.0
Type=Application
Name=ARIA (PySide)
Comment=ARIA assistant — PySide/Fluent desktop window
Exec=bash @JARVIS_ROOT@/scripts/launch-jarvis-pyside.sh
Icon=@JARVIS_ROOT@/assets/jarvis-tray.png
Path=@JARVIS_ROOT@
Terminal=false
Categories=Development;Utility;
StartupNotify=true
StartupWMClass=aria
Keywords=AI;ARIA;PySide;Fluent;Desktop;
