[Desktop Entry]
Version=1.0
Type=Application
Name=AI Workstation Status
Comment=Show workstation health and component status
Exec=@JARVIS_ROOT@/scripts/desktop-launch-workstation.sh report
Icon=@JARVIS_ROOT@/assets/jarvis-tray.png
Path=@HOME@
Terminal=false
Categories=Development;Utility;
Keywords=AI;Workstation;Status;
