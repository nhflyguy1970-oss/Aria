# Aria workstation configuration — copy to data/jarvis.env and customize.
# Never commit jarvis.env (secrets).

# Server
export JARVIS_HOST="127.0.0.1"
export JARVIS_PORT="8765"

# Models (adjust for your VRAM — see README)
export JARVIS_GENERAL_MODEL=""
export JARVIS_CODER_MODEL=""
export JARVIS_EMBED_MODEL="nomic-embed-text"
export JARVIS_VISION_MODEL="moondream:latest"

# Ollama
export OLLAMA_HOST="http://127.0.0.1:11434"
export OLLAMA_KEEP_ALIVE="30m"

# Self-healing / automation
export JARVIS_AUTO_RECOVER="1"
export JARVIS_AUTO_RECOVER_INTERVAL_MIN="5"
export JARVIS_AUTO_RECOVER_OPTIONAL="0"
export JARVIS_NIGHTLY_MAINTENANCE="1"
export JARVIS_MAINTENANCE_SMOKE_TESTS="0"

# Platform (when AI-Platform is co-installed)
# export AI_ROOT="/path/to/AI"
# export JARVIS_DISABLE_PLATFORM_ATTACHMENT="0"

# Voice (optional — set after install-dependencies.sh)
# export JARVIS_PIPER_MODEL=""
# export JARVIS_WHISPER_MODEL="base"

# LAN access (use ./scripts/enable-lan.sh instead of editing manually)
# export JARVIS_API_KEY=""
# export JARVIS_NETWORK_GUARD="1"
